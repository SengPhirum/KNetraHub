{
  "name": "knetrahub-portal",
  "version": "0.1.9",
  "private": true,
  "description": "KNetraHub - portal shell hosting KNetraHub-Docker (Docker Swarm management) and Module-Federation-loaded subsystem UIs",
  "author": "Seng Phirum <sengphirum143@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:swarm": "node scripts/dev-swarm.mjs",
    "dev:swarm:full": "node scripts/dev-swarm.mjs --profile full up --build",
    "dev:swarm:down": "node scripts/dev-swarm.mjs down",
    "dev:swarm:reset": "node scripts/dev-swarm.mjs down -v",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "build:docs": "NUXT_STATIC_DOCS=true nuxt generate",
    "preview:docs": "npx serve .output/public",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:it:pam": "vitest run --config vitest.integration.config.ts",
    "test:it:ssh": "node test/pam/integration/ssh-session.mjs",
    "test:it:linux": "node test/pam/integration/linux-connector.mjs",
    "test:it:ldap": "node test/pam/integration/ldap-connector.mjs",
    "test:it:mysql": "node test/pam/integration/mysql-connector.mjs",
    "test:it:mongo": "node test/pam/integration/mongo-connector.mjs",
    "test:e2e:pam": "node test/e2e/pam-e2e.mjs",
    "verify:pam": "node scripts/pam-verify.mjs",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/icon": "^1.10.3",
    "@nuxt/ui": "^4.8.2",
    "@resvg/resvg-js": "^2.6.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "^13.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.4.7",
    "dockerode": "^5.0.0",
    "exceljs": "^4.4.0",
    "grid-layout-plus": "^1.1.1",
    "jose": "^6.0.11",
    "ldapts": "^8.1.8",
    "mongodb": "^7.5.0",
    "mysql2": "^3.23.1",
    "nanoid": "^5.1.5",
    "net-snmp": "^3.26.3",
    "nuxt": "^4.4.7",
    "pg": "^8.13.1",
    "ping": "^1.0.0",
    "ssh2": "^1.17.0",
    "vue-chartjs": "^5.3.2",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@types/dockerode": "^4.0.1",
    "@types/pg": "^8.11.10",
    "playwright": "^1.61.1",
    "vitest": "^4.1.10"
  }
}
