# -----------------------------------------------------------
# KNetraHub configuration. Copy to `.env` and adjust.
# All variables are optional except a strong JWT secret in prod.
# (Env var / cookie / image / DB names keep the legacy "knetrahub" prefix on
# purpose - renaming them is a coordinated redeploy, not a config change.)
# -----------------------------------------------------------

# Session signing secret - set a long random string in production
NUXT_JWT_SECRET=change-me-to-a-long-random-string

# Default app name shown before an admin overrides it from Settings ->
# Appearance (that DB-stored override always wins once set).
# NUXT_PUBLIC_APP_NAME=KNetraHub

# Deployment environment mode: production | staging | development | testing
# (aliases prod/stg/sta/dev/test accepted). Setting it here FIXES the mode -
# the admin Settings -> Appearance page then shows it read-only. Leave unset
# to let an admin choose in the UI, or fall back to auto-detection from the
# serving domain (host containing staging/stg/sta -> Staging, development/dev
# -> Development, testing/test -> Testing, anything else -> Production).
# Every mode except production stamps a corner tag (Dev / Test / STG) on the
# app logo, favicon, and PWA icons.
# NUXT_ENV_MODE=staging

# First-run admin account - optional. Only takes effect if BOTH are set and
# no users exist yet; otherwise the app shows a one-time setup wizard on
# first launch that prompts for an admin username/password interactively.
# Leave both commented out to use the wizard instead of a fixed account.
# NUXT_ADMIN_USERNAME=admin
# NUXT_ADMIN_PASSWORD=change-me

# -- KNetraHub portal database --------------------------------
# These variables configure only the main portal database (identity, admin
# settings, preferences, audit, and module lifecycle metadata). Built-in
# subsystems never write their business data here. On first enable, an admin
# chooses a dedicated database for each module in Admin -> Modules; it may be
# created on this same PostgreSQL host or on a separate host.
#
# In the production Docker image, every NUXT_DB_* variable below also accepts
# a "_FILE" sibling that points at a file whose contents become the value -
# the same convention the official postgres/timescaledb image uses for
# POSTGRES_PASSWORD_FILE, so a value can come from a Docker Swarm or
# Kubernetes secret instead of plaintext in `docker inspect`/`docker service
# inspect`. Setting both a variable and its _FILE sibling is an error.
# e.g. NUXT_DB_PASSWORD_FILE=/run/secrets/knetrahub_db_password
# Resolved by docker/docker-entrypoint.sh - dev (`pnpm run dev`) reads these
# plain env vars directly and does not understand the _FILE suffix.
NUXT_DB_HOST=timescaledb
NUXT_DB_PORT=5432
NUXT_DB_NAME=knetrahub
NUXT_DB_USER=knetrahub
NUXT_DB_PASSWORD=change-me-to-a-long-random-string
NUXT_DB_SSL=false
# Portal traffic only. Each module has its own independently configured pool.
# Size PostgreSQL max_connections for the combined pools of enabled modules.
NUXT_DB_POOL_MAX=20

# How many days of Docker metrics history to retain in the Docker module's
# dedicated TimescaleDB database.
NUXT_METRICS_RETENTION_DAYS=30

# How many audit-log rows to retain (compliance trail, not an operational
# log - default is deliberately large; raise it further for your bank's
# retention policy).
NUXT_AUDIT_RETENTION_ROWS=200000

# -- Docker engine -------------------------------------------
# Local disposable swarm image used by docker/docker-compose.dev.yml.
# Override when you need to test a specific Docker Engine version.
# DOCKER_DIND_IMAGE=docker:29-dind

# Local socket (default). KNetraHub must run on / talk to a manager node.
NUXT_DOCKER_SOCKET_PATH=/var/run/docker.sock
# Local socket for Windows. KNetraHub must run on / talk to a manager node.
# NUXT_DOCKER_SOCKET_PATH=//./pipe/docker_engine
# ...or a remote engine over TCP (optionally TLS):
# NUXT_DOCKER_HOST=10.0.0.10
# NUXT_DOCKER_PORT=2376
# NUXT_DOCKER_CA=/certs/ca.pem
# NUXT_DOCKER_CERT=/certs/cert.pem
# NUXT_DOCKER_KEY=/certs/key.pem

# -- Per-node usage metrics -----------------------------------
# Live CPU/memory/disk usage per swarm node is reported by the knetrahub-agent
# service (deploy: mode: global - one task per node, talking only to its own
# local Docker socket). Set the same token on both the app and the agent so
# the app only accepts reports from your own agent tasks.
# Accepts NUXT_AGENT_TOKEN_FILE too (see docker/docker-entrypoint.sh). The
# agent service takes the same value under its own var name,
# KNETRAHUB_AGENT_TOKEN (or KNETRAHUB_AGENT_TOKEN_FILE) - see docker/docker-compose.yml.
NUXT_AGENT_TOKEN=change-me-to-a-long-random-string
# How long an agent's last report stays valid before a node shows as unavailable.
NUXT_AGENT_STALE_MS=20000

# -- LDAP (optional) -----------------------------------------
NUXT_LDAP_ENABLED=false
NUXT_LDAP_URL=ldaps://ldap.example.com:636
NUXT_LDAP_BIND_DN=cn=service,dc=example,dc=com
NUXT_LDAP_BIND_CREDENTIALS=service-password
NUXT_LDAP_SEARCH_BASE=ou=people,dc=example,dc=com
NUXT_LDAP_SEARCH_FILTER=(uid={{username}})
NUXT_LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=com
NUXT_LDAP_ADMIN_GROUP=cn=swarm-admins,ou=groups,dc=example,dc=com
NUXT_LDAP_OPERATOR_GROUP=cn=swarm-operators,ou=groups,dc=example,dc=com

# -- OIDC single sign-on (optional) --------------------------
# Authorization code flow with PKCE. Works with Keycloak, Authentik,
# Entra ID (Azure AD), Okta, Google, etc.
NUXT_OIDC_ENABLED=false
# Issuer URL - KNetraHub reads {issuer}/.well-known/openid-configuration
NUXT_OIDC_ISSUER=https://keycloak.example.com/realms/main
NUXT_OIDC_CLIENT_ID=knetrahub
NUXT_OIDC_CLIENT_SECRET=client-secret
# Optional - defaults to {origin}/api/auth/oidc/callback. Register this
# exact URL as an allowed redirect URI on the provider.
# NUXT_OIDC_REDIRECT_URI=https://knetrahub.example.com/api/auth/oidc/callback
# NUXT_OIDC_SCOPE=openid profile email groups
# Claims used to build the KNetraHub user
# NUXT_OIDC_USERNAME_CLAIM=preferred_username
# NUXT_OIDC_DISPLAY_NAME_CLAIM=name
# Claim that carries group names; dot-paths work (e.g. realm_access.roles)
# NUXT_OIDC_GROUPS_CLAIM=groups
# Group -> global role mapping; users without a matched group become viewers
NUXT_OIDC_ADMIN_GROUP=swarm-admins
NUXT_OIDC_OPERATOR_GROUP=swarm-operators
# Claim carrying Keycloak realm roles. These drive PER-APP access (which of
# Dock/Net/Server/IPMgt a user sees, and at what tier), configured under
# Settings -> Apps & Access. Keycloak's default location is realm_access.roles.
# NUXT_OIDC_ROLES_CLAIM=realm_access.roles
# Label for the login button, e.g. "Keycloak" or "Company SSO"
# NUXT_OIDC_PROVIDER_NAME=SSO

# -- GitLab stack versioning (optional) ----------------------
# Can also be configured entirely from Settings -> Integrations instead of
# env vars; the token is encrypted at rest either way. These are just defaults.
NUXT_GITLAB_URL=https://gitlab.com
NUXT_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
NUXT_GITLAB_PROJECT_ID=12345678
NUXT_GITLAB_BRANCH=main
NUXT_GITLAB_STACKS_PATH=stacks

# -- Alerts (optional) -----------------------------------------
# Notification channels (Telegram/Teams/Webhook) and per-rule thresholds are
# configured from Settings -> Alerts. These two vars only control the poller
# that checks usage/node/replica/disk conditions; deploy-failure alerts fire
# immediately regardless of the interval.
NUXT_ALERTS_ENABLED=true
NUXT_ALERTS_INTERVAL_MINUTES=3

# -- Monitoring module: real network device polling (optional) -
# The Monitoring app's Network side polls real devices with ICMP ping + SNMP
# v1/v2c/v3. The poller pings every device each cycle and reads SNMP
# system/interface data for SNMP devices; Monitoring > Discovery uses the same
# engine to scan a CIDR. Per-device SNMP version/community/v3 credentials are
# set on the device; the values below are defaults and fallbacks for v1/v2c.
# The runtime needs a working `ping` binary (Docker image installs it).
# See the "Monitoring (Network + Server)" section in README.md for details.
NUXT_NET_POLLING_ENABLED=true          # set false to stop all polling
NUXT_NET_POLL_INTERVAL_SECONDS=60      # how often each device is polled
NUXT_NET_POLL_CONCURRENCY=16           # devices polled in parallel
NUXT_NET_SNMP_COMMUNITY=public         # default SNMP community (per-device overrides win)
NUXT_NET_SNMP_VERSION=v2c              # default SNMP version: v1 | v2c
NUXT_NET_SNMP_TIMEOUT_MS=2000          # per-request SNMP timeout
NUXT_NET_PING_TIMEOUT_SECONDS=2        # per-host ICMP timeout
NUXT_NET_DISCOVERY_CONCURRENCY=64      # parallel hosts during a discovery scan

# -- Monitoring module: real server/host polling (optional) ----
# The Monitoring app's Server side (Zabbix-style) pings every enabled host,
# collects its SNMP items, evaluates triggers into problems, and fires
# actions on the same cycle. Disable with NUXT_SERVER_POLLING_ENABLED=false.
NUXT_SERVER_POLLING_ENABLED=true       # set false to stop all polling
NUXT_SERVER_POLL_INTERVAL_SECONDS=60   # how often each host is polled
NUXT_SERVER_POLL_CONCURRENCY=16        # hosts polled in parallel
NUXT_SERVER_SNMP_COMMUNITY=public      # default SNMP community (per-host overrides win)
NUXT_SERVER_SNMP_VERSION=v2c           # default SNMP version: v1 | v2c
NUXT_SERVER_SNMP_TIMEOUT_MS=2000       # per-request SNMP timeout
NUXT_SERVER_PING_TIMEOUT_SECONDS=2     # per-host ICMP timeout
NUXT_SERVER_DISCOVERY_CONCURRENCY=64   # parallel hosts during a discovery scan
NUXT_SERVER_WEB_TIMEOUT_MS=8000        # per-request timeout for web-scenario checks
# SNMP trap receiver - opt-in, off by default (it opens a UDP listener).
# Defaults to 1162, not the standard 162, since binding <1024 needs root/
# CAP_NET_BIND_SERVICE; production deployments typically forward 162->1162.
NUXT_SERVER_TRAP_ENABLED=false
NUXT_SERVER_TRAP_PORT=1162
NUXT_SERVER_TRAP_BIND_ADDRESS=0.0.0.0

# -- Auto-redeploy (optional) -----------------------------------
# Background poller that redeploys services opted into the
# knetrahub.autoredeploy label when their registry's image digest changes.
NUXT_AUTOREDEPLOY_ENABLED=true
NUXT_AUTOREDEPLOY_INTERVAL_MINUTES=15
NUXT_AUTOREDEPLOY_TIMEOUT_MS=10000

# Agent collector modes (comma-separated: docker,server,network,asset).
# Defaults to "docker" alone, so existing deployments are unaffected.
# server/network/asset are stubs today - see agent/collectors/.
KNETRAHUB_AGENT_MODE=docker

# ============================================================================
# KNetraHub PAM (Privileged Access Management)
# ============================================================================
# PAM runs as a native Nuxt layer (/pam, /api/pam/v1) with an isolated `pam`
# PostgreSQL schema in its own dedicated database (enable it in Admin > Modules,
# default name knetrahub_pam). The cryptographic vault, credential worker,
# audit chain and session control-plane all run in-process; the SSH gateway,
# guacd browser-session gateway and connector-runner are separate services (see
# docker/docker-compose.yml). Every *_FILE sibling is resolved by
# docker/docker-entrypoint.sh, so secrets can come from Docker/Swarm secrets.

# -- Cryptographic vault (REQUIRED in production) -------------------------------
# Master key (KEK) for envelope encryption of every credential/secret. NEVER
# derived from NUXT_JWT_SECRET. Accepts a plain passphrase (→ key version 1) or
# a JSON keyring for rotation: {"active":2,"keys":{"1":"...","2":"..."}}.
# In production a missing key makes the vault fail closed. Prefer the _FILE form
# backed by a Docker secret (knetrahub_pam_master_key).
# NUXT_PAM_MASTER_KEY=change-me-in-production-please
# NUXT_PAM_MASTER_KEY_FILE=/run/secrets/knetrahub_pam_master_key

# Keyed integrity signing for session recordings (falls back to the master key
# if unset; a dedicated key is recommended).
# NUXT_PAM_RECORDING_SIGNING_KEY_FILE=/run/secrets/knetrahub_pam_recording_signing_key

# Offline recovery material (split-knowledge shares) for master-key recovery.
# NUXT_PAM_RECOVERY_MATERIAL_FILE=/run/secrets/knetrahub_pam_recovery_material

# -- Credential worker ----------------------------------------------------------
# The in-process worker claims jobs from the pam.credential_jobs queue (FOR
# UPDATE SKIP LOCKED); set to false on web replicas that should not process jobs
# (dedicate the pam-worker service instead). Any number of workers cooperate.
NUXT_PAM_WORKER_ENABLED=true
NUXT_PAM_WORKER_NAME=                    # defaults to inproc-<pid>

# -- Session gateway ------------------------------------------------------------
# Address the SSH/guacd session gateway is reachable at (used to seed the
# default gateway record). The gateway authenticates session tokens with the
# same NUXT_JWT_SECRET, audience-scoped and short-lived.
NUXT_PAM_SSH_GATEWAY_ADDR=pam-ssh-gateway:4222
