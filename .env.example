# -----------------------------------------------------------
# KNetraHub configuration. Copy to `.env` and adjust.
# All variables are optional except a strong JWT secret in prod.
# (Env var / cookie / image / DB names keep the legacy "knetrahub" prefix on
# purpose - renaming them is a coordinated redeploy, not a config change.)
# -----------------------------------------------------------

# Session signing secret - set a long random string in production
NUXT_JWT_SECRET=change-me-to-a-long-random-string

# First-run admin account (created only if no users exist)
NUXT_ADMIN_USERNAME=admin
NUXT_ADMIN_PASSWORD=admin

# -- Postgres + TimescaleDB (app data + metrics history) -----
# Single instance: plain relational tables (users, settings, audit, ...)
# and Timescale hypertables (node/container metrics history) share one DB.
#
# In the production Docker image, every NUXT_DB_* variable below also accepts
# a "_FILE" sibling that points at a file whose contents become the value -
# the same convention the official postgres/timescaledb image uses for
# POSTGRES_PASSWORD_FILE, so a value can come from a Docker Swarm or
# Kubernetes secret instead of plaintext in `docker inspect`/`docker service
# inspect`. Setting both a variable and its _FILE sibling is an error.
# e.g. NUXT_DB_PASSWORD_FILE=/run/secrets/knetrahub_db_password
# Resolved by docker/docker-entrypoint.sh - dev (`pnpm run dev`) reads these
# plain env vars directly and does not understand the _FILE suffix.
NUXT_DB_HOST=timescaledb
NUXT_DB_PORT=5432
NUXT_DB_NAME=knetrahub
NUXT_DB_USER=knetrahub
NUXT_DB_PASSWORD=change-me-to-a-long-random-string
NUXT_DB_SSL=false
NUXT_DB_POOL_MAX=10

# How many days of metrics history (node/container/disk/network samples and
# service status events) to keep before Timescale's retention policy drops it.
NUXT_METRICS_RETENTION_DAYS=30

# How many audit-log rows to retain (compliance trail, not an operational
# log - default is deliberately large; raise it further for your bank's
# retention policy).
NUXT_AUDIT_RETENTION_ROWS=200000

# -- Docker engine -------------------------------------------
# Local disposable swarm image used by docker-compose.dev.yml.
# Override when you need to test a specific Docker Engine version.
# DOCKER_DIND_IMAGE=docker:29-dind

# Local socket (default). KNetraHub must run on / talk to a manager node.
NUXT_DOCKER_SOCKET_PATH=/var/run/docker.sock
# Local socket for Windows. KNetraHub must run on / talk to a manager node.
# NUXT_DOCKER_SOCKET_PATH=//./pipe/docker_engine
# ...or a remote engine over TCP (optionally TLS):
# NUXT_DOCKER_HOST=10.0.0.10
# NUXT_DOCKER_PORT=2376
# NUXT_DOCKER_CA=/certs/ca.pem
# NUXT_DOCKER_CERT=/certs/cert.pem
# NUXT_DOCKER_KEY=/certs/key.pem

# -- Per-node usage metrics -----------------------------------
# Live CPU/memory/disk usage per swarm node is reported by the knetrahub-agent
# service (deploy: mode: global - one task per node, talking only to its own
# local Docker socket). Set the same token on both the app and the agent so
# the app only accepts reports from your own agent tasks.
# Accepts NUXT_AGENT_TOKEN_FILE too (see docker/docker-entrypoint.sh). The
# agent service takes the same value under its own var name,
# KNETRAHUB_AGENT_TOKEN (or KNETRAHUB_AGENT_TOKEN_FILE) - see docker-compose.yml.
NUXT_AGENT_TOKEN=change-me-to-a-long-random-string
# How long an agent's last report stays valid before a node shows as unavailable.
NUXT_AGENT_STALE_MS=20000

# -- LDAP (optional) -----------------------------------------
NUXT_LDAP_ENABLED=false
NUXT_LDAP_URL=ldaps://ldap.example.com:636
NUXT_LDAP_BIND_DN=cn=service,dc=example,dc=com
NUXT_LDAP_BIND_CREDENTIALS=service-password
NUXT_LDAP_SEARCH_BASE=ou=people,dc=example,dc=com
NUXT_LDAP_SEARCH_FILTER=(uid={{username}})
NUXT_LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=com
NUXT_LDAP_ADMIN_GROUP=cn=swarm-admins,ou=groups,dc=example,dc=com
NUXT_LDAP_OPERATOR_GROUP=cn=swarm-operators,ou=groups,dc=example,dc=com

# -- OIDC single sign-on (optional) --------------------------
# Authorization code flow with PKCE. Works with Keycloak, Authentik,
# Entra ID (Azure AD), Okta, Google, etc.
NUXT_OIDC_ENABLED=false
# Issuer URL - KNetraHub reads {issuer}/.well-known/openid-configuration
NUXT_OIDC_ISSUER=https://keycloak.example.com/realms/main
NUXT_OIDC_CLIENT_ID=knetrahub
NUXT_OIDC_CLIENT_SECRET=client-secret
# Optional - defaults to {origin}/api/auth/oidc/callback. Register this
# exact URL as an allowed redirect URI on the provider.
# NUXT_OIDC_REDIRECT_URI=https://knetrahub.example.com/api/auth/oidc/callback
# NUXT_OIDC_SCOPE=openid profile email groups
# Claims used to build the KNetraHub user
# NUXT_OIDC_USERNAME_CLAIM=preferred_username
# NUXT_OIDC_DISPLAY_NAME_CLAIM=name
# Claim that carries group names; dot-paths work (e.g. realm_access.roles)
# NUXT_OIDC_GROUPS_CLAIM=groups
# Group -> global role mapping; users without a matched group become viewers
NUXT_OIDC_ADMIN_GROUP=swarm-admins
NUXT_OIDC_OPERATOR_GROUP=swarm-operators
# Claim carrying Keycloak realm roles. These drive PER-APP access (which of
# Dock/Net/Server/IPMgt a user sees, and at what tier), configured under
# Settings -> Apps & Access. Keycloak's default location is realm_access.roles.
# NUXT_OIDC_ROLES_CLAIM=realm_access.roles
# Label for the login button, e.g. "Keycloak" or "Company SSO"
# NUXT_OIDC_PROVIDER_NAME=SSO

# -- GitLab stack versioning (optional) ----------------------
# Can also be configured entirely from Settings -> Integrations instead of
# env vars; the token is encrypted at rest either way. These are just defaults.
NUXT_GITLAB_URL=https://gitlab.com
NUXT_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
NUXT_GITLAB_PROJECT_ID=12345678
NUXT_GITLAB_BRANCH=main
NUXT_GITLAB_STACKS_PATH=stacks

# -- Alerts (optional) -----------------------------------------
# Notification channels (Telegram/Teams/Webhook) and per-rule thresholds are
# configured from Settings -> Alerts. These two vars only control the poller
# that checks usage/node/replica/disk conditions; deploy-failure alerts fire
# immediately regardless of the interval.
NUXT_ALERTS_ENABLED=true
NUXT_ALERTS_INTERVAL_MINUTES=3

# -- Network module: real device monitoring (optional) --------
# The Network app polls real devices with ICMP ping + SNMP (v1/v2c). The poller
# pings every device each cycle and reads SNMP system/interface data for SNMP
# devices; Network > Discovery uses the same engine to scan a CIDR. Per-device
# SNMP version/community are set on the device; the values below are defaults
# and fallbacks. SNMPv3 (auth/priv) is not supported yet — v3 devices are pinged
# only. The runtime needs a working `ping` binary (Docker image installs it).
NUXT_NET_POLLING_ENABLED=true          # set false to stop all polling
NUXT_NET_POLL_INTERVAL_SECONDS=60      # how often each device is polled
NUXT_NET_POLL_CONCURRENCY=16           # devices polled in parallel
NUXT_NET_SNMP_COMMUNITY=public         # default SNMP community (per-device overrides win)
NUXT_NET_SNMP_VERSION=v2c              # default SNMP version: v1 | v2c
NUXT_NET_SNMP_TIMEOUT_MS=2000          # per-request SNMP timeout
NUXT_NET_PING_TIMEOUT_SECONDS=2        # per-host ICMP timeout
NUXT_NET_DISCOVERY_CONCURRENCY=64      # parallel hosts during a discovery scan

# -- KNetraHub subsystem modules (optional) -------------------
# Where the portal looks for each remote's remoteEntry.js and API. Defaults
# already point at the documented local dev ports, so npm run dev:mf works
# without setting any of these. Only KNetraHub-Net actually exists today
# (remotes/knetrahub-net + services/knetrahub-net-api); the Server/IPMgt
# entries are reserved for when those are built the same way.
NUXT_PUBLIC_KNETRAHUB_NET_REMOTE_ENTRY=http://localhost:3101/remoteEntry.js
NUXT_PUBLIC_KNETRAHUB_NET_API_BASE=http://localhost:4101/api
NUXT_PUBLIC_KNETRAHUB_SERVER_REMOTE_ENTRY=http://localhost:3102/remoteEntry.js
NUXT_PUBLIC_KNETRAHUB_SERVER_API_BASE=http://localhost:4102/api
NUXT_PUBLIC_KNETRAHUB_IPMGT_REMOTE_ENTRY=http://localhost:3103/remoteEntry.js
NUXT_PUBLIC_KNETRAHUB_IPMGT_API_BASE=http://localhost:4103/api

# Agent collector modes (comma-separated: docker,server,network,asset).
# Defaults to "docker" alone, so existing deployments are unaffected.
# server/network/asset are stubs today - see agent/collectors/.
KNETRAHUB_AGENT_MODE=docker
